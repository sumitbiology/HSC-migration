plt.xlabel('Spatial Position (x)', fontsize=12, fontweight='bold')
plt.ylabel('Binding Affinity (μ)', fontsize=12, fontweight='bold')
plt.title('Figure 4: Phenotypic Distribution of HSCs at t = 48h', fontsize=13, fontweight='bold')

# Add arrow to show phenotypic drift
plt.annotate('Phenotypic Drift\n(Stronger Binding)', xy=(0.8, 0.3), xytext=(0.4, 0.7),
             arrowprops=dict(arrowstyle='->', color='white', lw=2),
             color='white', fontsize=11, fontweight='bold')

plt.text(0.02, 0.98, 'B', transform=plt.gca().transAxes, fontsize=16, fontweight='bold', va='top', color='white')

plt.tight_layout()
plt.savefig('manuscript_figures/Figure4_Phenotypic_Distribution.png', dpi=600)
plt.savefig('manuscript_figures/Figure4_Phenotypic_Distribution.pdf', dpi=600)
plt.savefig('manuscript_figures/Figure4_Phenotypic_Distribution.svg', dpi=600)
plt.close()

# ============================================================================
# FIGURE 5: Synergy Analysis Heatmap
# ============================================================================
plt.figure(figsize=(10, 8))
lure_vals = np.linspace(1, 10, 50)
lock_vals = np.linspace(1, 5, 50)
L, K = np.meshgrid(lure_vals, lock_vals, indexing='ij')

# Create synergy surface (sigmoidal response)
synergy = 100 / (1 + np.exp(-(L - 5)/1.5)) * (1 - np.exp(-K/1.5))
synergy = np.minimum(synergy, 100)

plt.pcolormesh(lure_vals, lock_vals, synergy.T, cmap='hot', shading='auto', vmin=0, vmax=100)
cbar = plt.colorbar(label='Recruitment Efficiency (%)')
cbar.ax.tick_params(labelsize=10)

# Mark experimental condition
plt.scatter(8, 3.25, s=200, c='white', marker='*', edgecolors='black', linewidths=2, 
            label='Experimental Condition (8×, 3.25×)', zorder=10)

# Add contour lines for 50% and 90%
plt.contour(lure_vals, lock_vals, synergy.T, levels=[50, 90], colors='white', 
            linestyles='--', linewidths=1.5)

plt.xlabel('Lure Strength (Fold Upregulation)', fontsize=12, fontweight='bold')
plt.ylabel('Lock Strength (ICAM1 Enrichment)', fontsize=12, fontweight='bold')
plt.title('Figure 5: Synergy Analysis - Both Mechanisms Required for >90% Recruitment', 
          fontsize=13, fontweight='bold')
plt.legend(loc='upper left', frameon=True, fancybox=True, shadow=True)
plt.text(0.02, 0.98, 'C', transform=plt.gca().transAxes, fontsize=16, fontweight='bold', va='top')

plt.tight_layout()
plt.savefig('manuscript_figures/Figure5_Synergy_Analysis.png', dpi=600)
plt.savefig('manuscript_figures/Figure5_Synergy_Analysis.pdf', dpi=600)
plt.savefig('manuscript_figures/Figure5_Synergy_Analysis.svg', dpi=600)
plt.close()

# ============================================================================
