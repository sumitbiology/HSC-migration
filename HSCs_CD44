import numpy as np
import matplotlib.pyplot as plt
from matplotlib.colors import LinearSegmentedColormap
import os

# Create output directory
os.makedirs('manuscript_figures', exist_ok=True)

# Set publication-quality styling
plt.style.use('default')
plt.rcParams.update({
    'font.family': 'Arial',
    'font.size': 11,
    'axes.linewidth': 1.2,
    'axes.labelsize': 12,
    'axes.titlesize': 13,
    'xtick.labelsize': 10,
    'ytick.labelsize': 10,
    'legend.fontsize': 10,
    'figure.titlesize': 14,
    'figure.dpi': 600,
    'savefig.dpi': 600,
    'savefig.transparent': False,
    'savefig.bbox': 'tight',
    'savefig.pad_inches': 0.05
})

# Create custom colormap
colors = ['#00008B', '#0000FF', '#00FFFF', '#FFFF00', '#FFA500', '#FF0000', '#8B0000']
hot_cmap = LinearSegmentedColormap.from_list('custom_hot', colors, N=256)

# ============================================================================
# FIGURE 1: Migration Kinetics (Line plot with experimental validation)
# ============================================================================
plt.figure(figsize=(8, 6))
time_hours = np.linspace(0, 48, 100)
# Simulated data (replace with your actual simulation results)
sim_data = 100 / (1 + np.exp(-(time_hours - 24)/4))

plt.plot(time_hours, sim_data, 'b-', linewidth=2.5, label='Model Simulation')
plt.axhline(y=90, color='r', linestyle='--', linewidth=2, label='Experimental Threshold (90%)')
plt.fill_between(time_hours, 0, sim_data, alpha=0.1, color='blue')

# Add annotations for phases
plt.axvspan(0, 12, alpha=0.1, color='gray', label='Lag Phase')
plt.axvspan(12, 36, alpha=0.1, color='lightblue', label='Linear Migration')
plt.axvspan(36, 48, alpha=0.1, color='lightgreen', label='Saturation')

plt.xlabel('Time (hours)', fontweight='bold')
plt.ylabel('Migrated Population (%)', fontweight='bold')
plt.title('Figure 1: HSC Migration Kinetics Over 48 Hours', fontweight='bold')
plt.legend(loc='lower right', frameon=True, fancybox=True, shadow=True)
plt.grid(True, alpha=0.3, linestyle='--')
plt.text(0.02, 0.98, 'A', transform=plt.gca().transAxes, fontsize=16, fontweight='bold', va='top')

plt.tight_layout()
plt.savefig('manuscript_figures/Figure1_Migration_Kinetics.png', dpi=600)
plt.savefig('manuscript_figures/Figure1_Migration_Kinetics.pdf', dpi=600)
plt.savefig('manuscript_figures/Figure1_Migration_Kinetics.svg', dpi=600)
plt.close()

# ============================================================================
# FIGURE 2: Spatiotemporal Heatmaps (2×2 panel)
# ============================================================================
fig, axes = plt.subplots(2, 2, figsize=(12, 10))
X, Y = np.meshgrid(np.linspace(0, 1, 100), np.linspace(0, 1, 100))

time_points = [0, 12, 24, 48]
centers = [(0.1, 0.5), (0.3, 0.5), (0.6, 0.5), (0.9, 0.5)]
scales = [0.01, 0.02, 0.03, 0.02]
amplitudes = [1, 1.5, 2.5, 4]

for idx, (ax, t, center, scale, amp) in enumerate(zip(axes.flat, time_points, centers, scales, amplitudes)):
    Z = amp * np.exp(-((X - center[0])**2 + (Y - center[1])**2) / scale)
    
    im = ax.pcolormesh(X, Y, Z, cmap=hot_cmap, shading='auto', vmin=0, vmax=4)
    ax.set_xlabel('x (mm)', fontsize=11)
    ax.set_ylabel('y (mm)', fontsize=11)
    ax.set_title(f't = {t} hours', fontsize=12, fontweight='bold')
    ax.set_aspect('equal')
    ax.text(0.05, 0.95, f'{chr(65+idx)}', transform=ax.transAxes, 
            fontsize=14, fontweight='bold', va='top', ha='left')
    
    # Add colorbar for each subplot
    cbar = plt.colorbar(im, ax=ax, shrink=0.8)
    cbar.set_label('HSC Density', fontsize=10)

plt.suptitle('Figure 2: Spatiotemporal Evolution of HSC Migration', fontsize=14, fontweight='bold')
plt.tight_layout()
plt.savefig('manuscript_figures/Figure2_Spatiotemporal_Heatmaps.png', dpi=600)
plt.savefig('manuscript_figures/Figure2_Spatiotemporal_Heatmaps.pdf', dpi=600)
plt.savefig('manuscript_figures/Figure2_Spatiotemporal_Heatmaps.svg', dpi=600)
plt.close()

# ============================================================================
# FIGURE 3: Spatial Locking Profile with CSC Niche
# ============================================================================
plt.figure(figsize=(9, 6))
x_vals = np.linspace(0, 1, 200)
bound_density = 2 * np.exp(-(x_vals - 0.5)**2 / 0.01) + 0.5 * np.ones_like(x_vals)
icam1_profile = np.ones_like(x_vals)
icam1_profile[(x_vals > 0.4) & (x_vals < 0.6)] = 3.25

plt.plot(x_vals, bound_density, 'k-', linewidth=2.5, label='Bound HSC Density')
plt.fill_between(x_vals, 0, icam1_profile * 0.3, color='gold', alpha=0.4, label='ICAM1 Expression')
plt.axvspan(0.4, 0.6, alpha=0.2, color='orange', label='CSC Niche')

# Add markers for key features
plt.scatter([0.5], [bound_density[np.argmin(np.abs(x_vals - 0.5))]], 
            s=100, c='red', marker='*', edgecolors='black', linewidths=1.5, zorder=5)

plt.xlabel('Distance from Vascular Source (mm)', fontsize=12, fontweight='bold')
plt.ylabel('Density (normalized)', fontsize=12, fontweight='bold')
plt.title('Figure 3: Preferential HSC Accumulation at CSC Niches', fontsize=13, fontweight='bold')
plt.legend(loc='upper right', frameon=True, fancybox=True, shadow=True)
plt.grid(True, alpha=0.2, linestyle='--')
plt.text(0.02, 0.98, 'A', transform=plt.gca().transAxes, fontsize=16, fontweight='bold', va='top')

plt.tight_layout()
plt.savefig('manuscript_figures/Figure3_Locking_Profile.png', dpi=600)
plt.savefig('manuscript_figures/Figure3_Locking_Profile.pdf', dpi=600)
plt.savefig('manuscript_figures/Figure3_Locking_Profile.svg', dpi=600)
plt.close()

# ============================================================================
# FIGURE 4: Phenotypic Distribution Heatmap
# ============================================================================
plt.figure(figsize=(10, 8))
x_grid, mu_grid = np.meshgrid(np.linspace(0, 1, 100), np.linspace(0, 1, 50), indexing='ij')
# Create phenotypic distribution that shifts near tumor
phenotypic_dist = np.exp(-((mu_grid - 0.5)**2) / 0.05) * (1 + 2 * np.exp(-(x_grid - 1)**2 / 0.1))

plt.pcolormesh(x_grid, mu_grid, phenotypic_dist, cmap='viridis', shading='auto')
cbar = plt.colorbar(label='HSC Density')
